{
  "expo": {
    "name": "HaveAll",
    "slug": "haveall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060B14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haveall.portal"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060B14"
      },
      "package": "com.haveall.portal"
    },
    "plugins": []
  }
}
